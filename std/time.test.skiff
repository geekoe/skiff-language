import std

test "sleep returns immediately for non positive durations" {
  const before = Date.now()
  std.time.sleep(Duration.milliseconds(0))
  std.time.sleep(Duration.milliseconds(0 - 1))
  assert !Date.now().isBefore(before)
}

test "sleep delays the current request" {
  const before = Date.now()
  std.time.sleep(Duration.milliseconds(20))
  const after = Date.now()
  assert after.toEpochMilliseconds() >= before.toEpochMilliseconds() + 1
}

test "duration constructors use integer millisecond payloads" {
  const millis = Duration.milliseconds(2000)
  const seconds = Duration.seconds(2)

  assert millis.toMilliseconds() == 2000
  assert seconds.toMilliseconds() == millis.toMilliseconds()
}
