import std

test defaultRun false

function liveFileChunks(marker: string) -> Stream<bytes> {
  emit(bytes.fromUtf8("runtime-live-file-stream:"))
  emit(bytes.fromUtf8(marker))
  return null
}

function liveFileDoubleBytes(value: bytes) -> bytes {
  const parts = Array.empty<bytes>()
  parts.push(value)
  parts.push(value)
  return bytes.concat(parts)
}

function liveFileOneMiBChunk() -> bytes {
  let chunk = bytes.fromUtf8("0123456789abcdef")
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  return chunk
}

function liveFileStagedChunks(marker: string) -> Stream<bytes> {
  const chunk = liveFileOneMiBChunk()
  emit(chunk)
  emit(bytes.fromUtf8(marker))
  emit(chunk)
  return null
}

function liveFileSixtyFourMiBChunk() -> bytes {
  let chunk = liveFileOneMiBChunk()
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  chunk = liveFileDoubleBytes(chunk)
  return chunk
}

function liveFileOverLimitChunks() -> Stream<bytes> {
  emit(liveFileSixtyFourMiBChunk())
  emit(bytes.fromUtf8("x"))
  return null
}

test "live file runtime creates reads infos and deletes immutable file" {
  const marker = config.require<string>("runtimeLive.file")
  const text = "runtime-live-file:".concat(marker)
  const file = std.file.createText(text, std.file.CreateOptions {
    contentType: "text/plain",
    purpose: "runtime-live",
  })

  assert file.id != ""
  assert file.size > 0
  assert file.sha256 != ""
  assert file.contentType == "text/plain"
  assert std.file.readText(file) == text

  const info = std.file.info(file)
  assert info.id == file.id
  assert info.size == file.size
  assert info.sha256 == file.sha256
  assert info.contentType == "text/plain"
  assert info.purpose == "runtime-live"

  std.file.delete(file)
  assert true
}

test "live file runtime writes chunks from stream and reports deleted file as missing" {
  const marker = config.require<string>("runtimeLive.file")
  const file = std.file.createFromStream(liveFileChunks(marker), std.file.CreateOptions {
    contentType: "text/plain",
    purpose: "runtime-live-stream",
  })

  assert file.size > 0
  assert std.file.readText(file) == "runtime-live-file-stream:".concat(marker)

  const info = std.file.info(file)
  assert info.purpose == "runtime-live-stream"

  std.file.delete(file)
  const missing = catch<std.file.FileError>(std.file.readText(file))
  assert missing.tag == "err"
}

test "live file runtime writes generated chunks through staged file path" {
  const marker = config.require<string>("runtimeLive.file")
  const file = std.file.createFromStream(liveFileStagedChunks(marker), std.file.CreateOptions {
    contentType: "application/octet-stream",
    purpose: "runtime-live-staged-stream",
  })

  assert file.size > 2097152
  assert std.file.read(file).length() == file.size

  const info = std.file.info(file)
  assert info.size == file.size
  assert info.purpose == "runtime-live-staged-stream"

  std.file.delete(file)
  const missing = catch<std.file.FileError>(std.file.info(file))
  assert missing.tag == "err"
}

test "live file runtime rejects stream above file guard limit" {
  const file = std.file.createFromStream(liveFileOverLimitChunks(), std.file.CreateOptions {
    contentType: "application/octet-stream",
    purpose: "runtime-live-over-limit-stream",
  })
  std.file.delete(file)
  assert false
}
